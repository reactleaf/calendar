{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 120,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    ".pnpm-store",
    "pnpm-lock.yaml",
    "docs/build",
    "docs/.react-router",
    "docs/.source",
    "docs/node_modules",
  ],
}
